# Required
TELEGRAM_TOKEN=
TELEGRAM_ALLOWLIST=

# Conversation and budget limits
MAX_CONTEXT_TOKENS=4000
SOFT_BUDGET=10.0
HARD_BUDGET=20.0
COST_PER_TOKEN=0.00001

# Logging
LOG_LEVEL=info

# OpenAI-compatible LLM API
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_MAX_RETRIES=5

# Ollama fallback/local model support
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_API_KEY=
OLLAMA_WEB_BASE_URL=https://ollama.com/api
MAX_TOOL_ITERATIONS=10

# Wiki and search storage
WIKI_PATH=./wiki
DB_PATH=./aura.db

# Embeddings
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# Health and tracing
HTTP_PORT=:8080
OTEL_ENABLED=false
