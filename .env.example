# Aura — minimal environment file
#
# Most configuration now lives in the dashboard's Settings page, persisted
# to aura.db. The values below are the bootstrap-only fields that must be
# present BEFORE the bot can start.
#
# First-run flow:
#   1. Leave TELEGRAM_TOKEN blank.
#   2. Run aura — it boots a setup wizard at http://127.0.0.1:8080.
#   3. Open the URL, paste your bot token, pick an LLM provider, save.
#   4. The wizard writes TELEGRAM_TOKEN here and the rest to aura.db.
#
# After setup, edit anything from the dashboard's Settings page —
# no restart needed for most fields.

# Required after first-run setup (or paste here manually).
TELEGRAM_TOKEN=

# Where the dashboard listens. 127.0.0.1 is loopback-only (recommended).
# Set 0.0.0.0:8080 to expose on your LAN — bearer auth still required.
HTTP_PORT=127.0.0.1:8080

# SQLite file holding settings, conversations, tasks, auth tokens, and
# the embedding cache. One file = one backup artifact.
DB_PATH=./aura.db

# Filesystem roots. These stay in env because the running process
# already has them open.
WIKI_PATH=./wiki
SKILLS_PATH=./skills
MCP_SERVERS_PATH=./mcp.json
PROMPT_OVERLAY_PATH=.

# Log verbosity: debug | info | warn | error.
LOG_LEVEL=info

# ─── Advanced (rarely changed) ─────────────────────────────────────
# Everything below has a sensible default. Edit from the dashboard
# Settings page; only set here if you need a value before first boot.
#
# TELEGRAM_ALLOWLIST=
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.mistral.ai/v1
# EMBEDDING_MODEL=mistral-embed
# MISTRAL_API_KEY=
# OCR_ENABLED=true
# SOFT_BUDGET=10.0
# HARD_BUDGET=20.0
# COST_PER_TOKEN=0.00001
# MAX_CONTEXT_TOKENS=125000
# MAX_HISTORY_MESSAGES=50
# MAX_TOOL_ITERATIONS=10
# SUMMARIZER_MODE=off
# SKILLS_ADMIN=false
# AURABOT_ENABLED=false
# AURABOT_MAX_ACTIVE=4
# AURABOT_MAX_DEPTH=1
# AURABOT_TIMEOUT_SEC=300
# AURABOT_MAX_ITERATIONS=5
# OTEL_ENABLED=false
# CONV_ARCHIVE_ENABLED=true

# ─── Sandbox (Isola WASM) ────────────────────────────────────────────
# SANDBOX_ENABLED=true
# SANDBOX_TIMEOUT_SEC=15

# ─── E2E (Playwright) ──────────────────────────────────────────────
# Mint AURA_E2E_TOKEN once via the request_dashboard_token Telegram tool.
AURA_DASHBOARD_URL=http://localhost:8080
AURA_E2E_TOKEN=
AURA_E2E_CHAT_ID=
