# Required
TELEGRAM_TOKEN=
# Optional on first run. Leave blank to let the first Telegram /start claim
# this Aura install; set comma-separated Telegram user IDs to disable bootstrap.
TELEGRAM_ALLOWLIST=

# Conversation and budget limits
MAX_CONTEXT_TOKENS=4000
SOFT_BUDGET=10.0
HARD_BUDGET=20.0
COST_PER_TOKEN=0.00001

# Logging
LOG_LEVEL=info

# OpenAI-compatible LLM API
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_MAX_RETRIES=5

# Ollama fallback/local model support
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_API_KEY=
OLLAMA_WEB_BASE_URL=https://ollama.com/api
MAX_TOOL_ITERATIONS=10

# Wiki and search storage
WIKI_PATH=./wiki
SKILLS_PATH=./skills
SKILLS_CATALOG_URL=https://skills.sh/
# Optional MCP servers config. JSON file with `mcpServers` map; missing file
# means no MCP servers. See mcp.example.json for the format.
MCP_SERVERS_PATH=./mcp.json
DB_PATH=./aura.db

# Embeddings
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.mistral.ai/v1
EMBEDDING_MODEL=mistral-embed

# Health and tracing
# Bind localhost-only by default. To expose to the LAN (only after slice 10d
# bearer auth ships) set HTTP_PORT=0.0.0.0:8080.
HTTP_PORT=127.0.0.1:8080
OTEL_ENABLED=false

# Mistral Document AI OCR (PDF ingestion)
# Keep separate from LLM_API_KEY and EMBEDDING_API_KEY.
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_OCR_BASE_URL=https://api.mistral.ai/v1
MISTRAL_OCR_TABLE_FORMAT=markdown
MISTRAL_OCR_INCLUDE_IMAGES=false
MISTRAL_OCR_EXTRACT_HEADER=false
MISTRAL_OCR_EXTRACT_FOOTER=false
OCR_ENABLED=true
OCR_MAX_PAGES=500
OCR_MAX_FILE_MB=100
